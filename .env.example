# =====================================================================
# MellogangVisuals — example environment
# Copy ke .env lalu isi nilai riil. JANGAN commit .env.
# =====================================================================

# ---- App ----
CI_ENVIRONMENT = development
app.baseURL    = 'http://localhost:8080/'
app.indexPage  = ''
app.debug      = true
app.forceGlobalSecureRequests = false
app.CSPEnabled = false

# ---- Database ----
# Produksi: Neon Postgres (serverless). Ambil connection string dari
# https://console.neon.tech -> project -> Connection Details.
database.default.hostname = ep-xxxxx.ap-southeast-1.aws.neon.tech
database.default.database = neondb
database.default.username = neondb_owner
database.default.password = isi_password_neon
database.default.port     = 5432
database.default.DBDriver = Postgre
database.default.charset  = utf8
database.default.sslmode  = require
# Wajib kalau libpq server hosting belum support SNI (error "Endpoint ID is
# not specified"): isi endpoint ID = bagian pertama hostname (ep-xxxxx).
# database.default.options = endpoint=ep-xxxxx

# Alternatif dev lokal MySQL/MariaDB (XAMPP):
# database.default.hostname = 127.0.0.1
# database.default.database = mellogang_db
# database.default.username = root
# database.default.password =
# database.default.port     = 3306
# database.default.DBDriver = MySQLi
# database.default.charset  = utf8mb4
# database.default.DBCollat = utf8mb4_unicode_ci

# ---- Midtrans Snap ----
# Sandbox: https://dashboard.sandbox.midtrans.com -> Settings -> Access Keys.
# Production cutover: ganti keys, isProduction=true, set Payment Notification
# URL di dashboard ke https://<backend>/payment/midtrans/notify (HTTPS only).
midtrans.serverKey    = SB-Mid-server-xxxx
midtrans.clientKey    = SB-Mid-client-xxxx
midtrans.isProduction = false
midtrans.merchantId   = Gxxxxxxxxx

# ---- Encryption ----
# encryption.key = (generate via `php spark key:generate`)

# ---- Session ----
# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null

# ---- SMTP (untuk Mailer) ----
email.SMTPHost   = smtp.gmail.com
email.SMTPUser   = you@gmail.com
email.SMTPPass   = your_app_password_here
email.SMTPPort   = 587
email.SMTPCrypto = tls
email.fromEmail  = no-reply@mellogang.test
email.fromName   = MellogangVisuals

# Untuk testing: tulis ke file spool, jangan kirim sungguhan.
# email.protocol = 'file'
# email.mailPath = '/path/to/writable/email-spool/'

# ---- Google OAuth (Sign in with Google) ----
# Bikin OAuth Client di https://console.cloud.google.com (Web).
# Isi Authorized redirect URI = GOOGLE_REDIRECT_URI di bawah.
GOOGLE_CLIENT_ID     = xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET = xxxx
GOOGLE_REDIRECT_URI  = http://localhost:8080/auth/google/callback

# ---- Social fetcher (Playwright, Node) ----
# URL/handle channel YouTube brand.
YT_CHANNEL_URL        = https://www.youtube.com/@mellogangvisuals/videos
# Username Instagram (tanpa @).
IG_HANDLE             = mellogangvisuals
# Path ke storageState hasil login IG manual (lihat README).
# File ini JANGAN di-commit.
IG_STORAGE_STATE_PATH = writable/secure/ig_state.json
SOCIAL_MAX_ITEMS      = 12
SOCIAL_HEADLESS       = true
